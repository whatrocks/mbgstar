---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Money Back Guarantee*',
  description = 'Money Back Guarantee*'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="wordmark" aria-label="Money Back Guarantee*">Money Back Guarantee*</div>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
