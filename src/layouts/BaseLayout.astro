---
import '../styles/global.css';
import FlyingMacs from '../components/FlyingMacs.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Money Back Guarantee*',
  description = 'Money Back Guarantee*'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <FlyingMacs />
    <div class="page-shell">
      <header class="site-header">
        <a href="/" class="wordmark" aria-label="Money Back Guarantee*">Money Back Guarantee*</a>
        <nav class="site-nav">
          <a href="/shows">Shows</a>
          <a href="https://mbgstar.bandcamp.com" target="_blank" rel="noopener noreferrer">Music</a>
          <a href="/coloring">Coloring</a>
          <a href="/about">About</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <nav class="social-links" aria-label="Social media">
          <a href="https://instagram.com/moneybackguaranteeasterisk" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            <span>Instagram</span>
          </a>
          <a href="https://youtube.com/@moneybackguaranteeasterisk" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
            </svg>
            <span>YouTube</span>
          </a>
          <a href="https://mbgstar.bandcamp.com" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M2 18l6-12h14L16 18H2z"></path>
            </svg>
            <span>Bandcamp</span>
          </a>
        </nav>
        <h2>Join the mailing list</h2>
        <iframe
          src="https://moneybackguarantee.substack.com/embed"
          title="Subscribe to Money Back Guarantee* on Substack"
          width="100%"
          height="320"
          style="border:2px solid var(--ink); background: var(--paper);"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </footer>
    </div>
  </body>
</html>
