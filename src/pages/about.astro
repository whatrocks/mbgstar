---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Money Back Guarantee*">
  <h1>About</h1>
  <figure class="image-stage">
    <img src="/band.jpg" alt="Money Back Guarantee*" />
  </figure>
  <p>
    Money Back Guarantee* is a band of dads hailing from Marin County and the
    East Bay playing originals and covers, after bedtime. They're always ready to rock, as
    long as the dishes are done, the dog's walked, and the
    laundry's running.
  </p>
</BaseLayout>
