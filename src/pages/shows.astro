---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shows — Money Back Guarantee*">
  <h1>Shows</h1>

  <section>
    <h2>Upcoming Shows</h2>
    <p>Check back soon!</p>
  </section>

  <section>
    <h2>Past Shows</h2>
    <ul class="show-list">
      <li>
        <span class="show-date">June 6, 2026</span>
        <span class="show-name">Private House Party</span>
      </li>
      <li>
        <span class="show-date">Feb 28, 2026</span>
        <span class="show-name">Private House Party</span>
      </li>
    </ul>
  </section>
</BaseLayout>

<style>
  section {
    margin-bottom: 2rem;
  }

  .show-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .show-list li {
    display: flex !important;
    gap: 1rem;
    align-items: baseline;
  }

  .show-date {
    font-weight: 700;
    min-width: 8rem;
  }
</style>
