---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import { site } from '../data/site';
---

<BaseLayout title="Shows" description="Upcoming live shows for Money Back Guarantee*.">
  <section class="page-intro">
    <p class="eyebrow">Shows</p>
    <h1>Upcoming Dates</h1>
    <p>Booking, ticket links, and flyer swaps can all route through this page.</p>
  </section>

  <section class="show-grid">
    {site.upcomingShows.map((show) => (
      <article class="show-card">
        <p class="show-date">{show.date}</p>
        <h2>{show.city}</h2>
        <p>{show.venue}</p>
        <p class="show-note">{show.note}</p>
        <a href={site.newsletterUrl} target="_blank" rel="noreferrer">Get updates</a>
      </article>
    ))}
  </section>

  <Newsletter compact />
</BaseLayout>
